# TrackSpendZ v2 - Environment Variables
# Copy this file to .env and fill in your values

# Supabase (Required)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# VITE_GEMINI_API_KEY — DEV ONLY. This key is exposed in the client bundle.
# In production, remove this and use the Supabase Edge Function instead.
# See supabase/functions/ai-proxy/README.md for deployment instructions.
VITE_GEMINI_API_KEY=

# ─── Razorpay (Optional — enables payment processing) ───────────────────────
# VITE_RAZORPAY_KEY_ID is the publishable key (rzp_test_... or rzp_live_...).
# Safe to ship in the client bundle. Get it from Razorpay Dashboard →
# Settings → API Keys.
#
# All other Razorpay secrets (key secret, webhook secret, plan IDs) live in
# Supabase Edge Function secrets, NOT here. See RAZORPAY_SETUP.md for the
# full setup checklist.
VITE_RAZORPAY_KEY_ID=

# Admin (Optional — comma-separated emails that can access /ctrl-room-7x9k)
VITE_ADMIN_EMAILS=admin@example.com

# ─── Supabase Edge Function secrets ──────────────────────────────────────────
# These are NOT frontend vars — set them via:
#   supabase secrets set RAZORPAY_KEY_SECRET=...
# or Supabase Dashboard → Edge Functions → <function> → Secrets
#
# Razorpay (server-side):
#   RAZORPAY_KEY_ID
#   RAZORPAY_KEY_SECRET
#   RAZORPAY_WEBHOOK_SECRET
#   RAZORPAY_PLAN_PRO_INR_MONTHLY
#   RAZORPAY_PLAN_PRO_INR_YEARLY
#   RAZORPAY_PLAN_PRO_USD_MONTHLY            (optional — falls back to INR)
#   RAZORPAY_PLAN_PRO_USD_YEARLY             (optional)
#   RAZORPAY_PLAN_ENTERPRISE_INR_MONTHLY
#   RAZORPAY_PLAN_ENTERPRISE_INR_YEARLY
#   RAZORPAY_PLAN_ENTERPRISE_USD_MONTHLY     (optional)
#   RAZORPAY_PLAN_ENTERPRISE_USD_YEARLY      (optional)
#
# Resend (Required for welcome emails)
# RESEND_API_KEY=re_your-resend-api-key

# Webhook shared secret (Optional but recommended — prevents unauthorized calls)
# WEBHOOK_SECRET=your-random-secret
